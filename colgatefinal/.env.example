# Variables de entorno - Agente Corporativo Colgate-Palmolive (Ruta B OpenFang)
# Copiar como .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio

# ── Mistral AI ──────────────────────────────────────────────────────────────
# Obtener en: https://console.mistral.ai -> API Keys
MISTRAL_API_KEY=

# ── WhatsApp Business (Meta Cloud API) ──────────────────────────────────────
# Obtener en: https://developers.facebook.com -> App -> WhatsApp -> Comenzar
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=1187696734416861
# Token de verificacion del webhook (valor libre, debe coincidir en Meta Developer Console)
WA_VERIFY_TOKEN=

# ── OpenFang ────────────────────────────────────────────────────────────────
# URL de la API REST del daemon OpenFang (default: http://127.0.0.1:50051)
OPENFANG_URL=http://127.0.0.1:4200
# UUID del agente colgate-assistant
# Obtener ejecutando: openfang agent list
OPENFANG_AGENT_ID=
