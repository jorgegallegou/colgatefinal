# =============================================================================
# Agente Corporativo Colgate-Palmolive Colombia — Ruta B OpenFang 0.6.9
# -----------------------------------------------------------------------------
# 1. Copiar este archivo:  cp .env.example .env
# 2. Completar los valores reales en .env
# 3. NUNCA commitear .env al repositorio
# =============================================================================


# -----------------------------------------------------------------------------
# Mistral AI
# Obtener en: https://console.mistral.ai -> API Keys
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=


# -----------------------------------------------------------------------------
# WhatsApp Business (Meta Cloud API)
# Obtener en: https://developers.facebook.com -> App -> WhatsApp -> Comenzar
# -----------------------------------------------------------------------------
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_VERIFY_TOKEN=          # valor libre, debe coincidir en Meta Developer Console


# -----------------------------------------------------------------------------
# OpenFang
# -----------------------------------------------------------------------------
OPENFANG_URL=http://127.0.0.1:4200          # puerto REST del daemon
OPENFANG_AGENT_ID=                          # ver: openfang agent list
